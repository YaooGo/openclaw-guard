{
  "name": "openclaw-guard",
  "version": "1.0.0",
  "description": "OpenClaw 安全卫士 - AI 编程助手安全检测与监控工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "cd ../frontend && npm run build",
    "build-go": "cd ../backend && go build -o ../electron/bin/guard ./cmd/guard",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --x64",
    "dist:mac:arm64": "electron-builder --mac --arm64",
    "dist:mac:all": "electron-builder --mac --x64 --arm64",
    "dist:mac:universal": "electron-builder --mac --x64 --arm64"
  },
  "build": {
    "appId": "com.openclaw.guard",
    "productName": "OpenClaw Guard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "bin/guard"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities",
      "icon": "../build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSAppleEventsUsageDescription": "OpenClaw Guard needs this to monitor AI assistant activity."
      }
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
